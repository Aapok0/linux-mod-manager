{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    "schedule:weekly"
  ],
  "packageRules": [
    {
      "description": "Group CI deps (Actions + workflow tool pins)",
      "matchManagers": ["github-actions", "custom.regex"],
      "groupName": "ci dependencies"
    },
    {
      "description": "Automerge CI-validated workflow updates",
      "matchManagers": ["github-actions", "custom.regex"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Lockfiles regenerated by pip-compile postUpgradeTasks",
      "matchFileNames": ["requirements.txt", "requirements-dev.txt"],
      "enabled": false
    },
    {
      "description": "Recompile lockfiles after pyproject dependency bumps",
      "matchManagers": ["pep621"],
      "postUpgradeTasks": {
        "commands": [
          "pip install pip-tools",
          "pip-compile requirements.in -o requirements.txt --strip-extras",
          "pip-compile requirements-dev.in -o requirements-dev.txt --strip-extras"
        ],
        "fileFilters": ["requirements.txt", "requirements-dev.txt"],
        "executionMode": "update"
      }
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "CI tool versions in workflow env (annotated with # renovate:)",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.ya?ml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: versioning=(?<versioning>\\S+))?\\s+\\w+_VERSION:\\s*[\"']?(?<currentValue>[^\"'\\s]+)"
      ]
    }
  ]
}
